<!DOCTYPE html>
<html lang="sq">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Rezultatet e Fluturimeve - AirKosova</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,wght@0,300;0,400;0,500;0,600;0,700;1,400&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <link rel="stylesheet" href="/css/styles.css">
    <link rel="stylesheet" href="/css/flights.css">
</head>
<body class="flights-page">
    <!-- Top Bar -->
    <div class="top-bar">
        <div class="top-bar-left">
            <a href="tel:+38338660880"><i class="fas fa-phone"></i> +383 38 660 880</a>
            <a href="mailto:info@airkosova.net"><i class="fas fa-envelope"></i> info@airkosova.net</a>
        </div>
        <div class="top-bar-right">
            <div class="language-selector">
                <i class="fas fa-globe"></i>
                <span>AL</span>
                <span>DE</span>
                <span>EN</span>
            </div>
        </div>
    </div>

    <!-- Header -->
    <header class="flights-header">
        <nav class="main-nav">
            <a href="/" class="logo">
                <img src="/images/airkosova_logo.png" alt="AirKosova" class="logo-img">
            </a>
            <div class="nav-links">
                <a href="/"><i class="fas fa-home"></i></a>
                <a href="#"><i class="fas fa-plane"></i> REZERVO</a>
                <a href="/contact">KONTAKT</a>
            </div>
            
            <!-- Hamburger Menu Button (Mobile) -->
            <button class="hamburger" id="hamburgerBtn" aria-label="Toggle menu">
                <span></span>
                <span></span>
                <span></span>
            </button>
        </nav>
        
        <!-- Mobile Menu Overlay -->
        <div class="mobile-overlay" id="mobileOverlay"></div>
        
        <!-- Mobile Menu Panel -->
        <div class="mobile-menu" id="mobileMenu">
            <div class="mobile-menu-links">
                <a href="/"><i class="fas fa-home"></i> Home</a>
                <a href="#"><i class="fas fa-plane"></i> Rezervo</a>
                <a href="/info/siguria"><i class="fas fa-shield-alt"></i> Siguria</a>
                <a href="/info/bagazhi"><i class="fas fa-suitcase-rolling"></i> Bagazhi</a>
                <a href="/contact"><i class="fas fa-envelope"></i> Kontakt</a>
            </div>
        </div>
    </header>

    <!-- Search Summary -->
    <div class="search-summary">
        <div class="search-summary-content">
            <div class="route-info">
                <div class="city from">
                    <span class="city-name" id="fromCity">—</span>
                    <span class="city-code" id="fromCode">—</span>
                </div>
                <div class="route-arrow"><i class="fas fa-arrow-right"></i></div>
                <div class="city to">
                    <span class="city-name" id="toCity">—</span>
                    <span class="city-code" id="toCode">—</span>
                </div>
            </div>
            <div class="search-details">
                <span><i class="fas fa-calendar"></i> <span id="dateRange">—</span></span>
                <span><i class="fas fa-user"></i> <span id="passengers">—</span></span>
            </div>
            <button class="modify-search-btn" onclick="window.location.href='/'">
                <i class="fas fa-search"></i> Kërkim i ri
            </button>
        </div>
    </div>

    <!-- Main Content -->
    <main class="flights-main">
        <!-- Loading State -->
        <div class="loading-state" id="loadingState">
            <div class="loader">
                <div class="plane-animation">
                    <i class="fas fa-plane fa-2x"></i>
                </div>
                <div class="loader-text">Duke kërkuar fluturime...</div>
                <div class="loader-subtext">Po kontrollojmë oraret dhe çmimet</div>
                <div class="loader-progress">
                    <div class="progress-bar"></div>
                </div>
            </div>
        </div>

        <!-- Flight Results -->
        <div class="flights-results" id="flightsResults" style="display: none;">
            
            <!-- Outbound Flights Section -->
            <section class="flight-section">
                <div class="section-header">
                    <h2><i class="fas fa-plane-departure"></i> Fluturimi i Nisjes</h2>
                    <span class="route-label" id="outboundRouteLabel">PRN → BSL</span>
                </div>
                <div class="flight-cards" id="outboundFlights">
                    <!-- Flight cards will be inserted here -->
                </div>
            </section>

            <!-- Return Flights Section -->
            <section class="flight-section" id="returnSection">
                <div class="section-header">
                    <h2><i class="fas fa-plane-arrival"></i> Fluturimi i Kthimit</h2>
                    <span class="route-label" id="returnRouteLabel">BSL → PRN</span>
                </div>
                <div class="flight-cards" id="returnFlights">
                    <!-- Flight cards will be inserted here -->
                </div>
            </section>

            <!-- Booking Summary Bar -->
            <div class="booking-bar">
                <div class="booking-bar-content">
                    <div class="selection-summary">
                        <div class="selected-flight outbound">
                            <span class="label"><i class="fas fa-plane-departure"></i> Nisja</span>
                            <span class="value" id="selectedOutbound">Zgjidhni fluturimin</span>
                        </div>
                        <div class="selected-flight return">
                            <span class="label"><i class="fas fa-plane-arrival"></i> Kthimi</span>
                            <span class="value" id="selectedReturn">Zgjidhni fluturimin</span>
                        </div>
                    </div>
                    <div class="total-section">
                        <div class="total-label">Totali</div>
                        <div class="total-amount" id="totalPrice">CHF 0.00</div>
                    </div>
                    <button id="bookNowBtn" class="book-btn">
                        Rezervo Tani <i class="fas fa-arrow-right"></i>
                    </button>
                </div>
            </div>
        </div>

    </main>

    <!-- Footer -->
    <footer class="flights-footer">
        <p>© 2025 AirKosova</p>
    </footer>

    <script>
        // Get search params from URL
        const urlParams = new URLSearchParams(window.location.search);
        const searchParams = {
            departure: urlParams.get('departure') || 'Prishtina',
            destination: urlParams.get('destination') || 'Basel',
            departureDate: urlParams.get('departureDate') || '',
            returnDate: urlParams.get('returnDate') || '',
            adults: urlParams.get('adults') || '1',
            children: urlParams.get('children') || '0',
            infants: urlParams.get('infants') || '0',
            tripType: urlParams.get('tripType') || 'roundtrip'
        };

        // City codes
        const cities = <%- JSON.stringify(cities) %>;
        
        // Selection state
        let selectedOutbound = null;
        let selectedReturn = null;
        
        // Performance tracking
        const frontendTiming = {
            pageLoadStart: performance.now(),
            apiCallStart: null,
            apiCallEnd: null,
            renderStart: null,
            renderEnd: null,
            searchClickEpoch: null,
            resultsRenderedEpoch: null
        };

        // Pull the "search button pressed" timestamp from the homepage (stored in sessionStorage).
        try {
            const v = sessionStorage.getItem('ak_search_click_ts');
            frontendTiming.searchClickEpoch = v ? parseInt(v, 10) : null;
        } catch (e) {
            frontendTiming.searchClickEpoch = null;
        }

        // Format date for display
        function formatDate(dateStr) {
            if (!dateStr) return '—';
            const date = new Date(dateStr);
            return date.toLocaleDateString('sq-AL', { weekday: 'short', day: '2-digit', month: 'short' });
        }

        // Update page header
        function updateHeader() {
            const fromCode = cities[searchParams.departure] || 'PRN';
            const toCode = cities[searchParams.destination] || 'BSL';
            
            document.getElementById('fromCity').textContent = searchParams.departure;
            document.getElementById('fromCode').textContent = fromCode;
            document.getElementById('toCity').textContent = searchParams.destination;
            document.getElementById('toCode').textContent = toCode;
            
            const dateFrom = formatDate(searchParams.departureDate);
            const dateTo = formatDate(searchParams.returnDate);
            document.getElementById('dateRange').textContent = dateTo !== '—' ? `${dateFrom} — ${dateTo}` : dateFrom;
            
            const total = parseInt(searchParams.adults) + parseInt(searchParams.children) + parseInt(searchParams.infants);
            document.getElementById('passengers').textContent = `${total} Pasagjer${total > 1 ? 'ë' : ''}`;
            
            document.getElementById('outboundRouteLabel').textContent = `${fromCode} → ${toCode}`;
            document.getElementById('returnRouteLabel').textContent = `${toCode} → ${fromCode}`;
            
            // Hide return section for one-way
            if (searchParams.tripType === 'oneway') {
                document.getElementById('returnSection').style.display = 'none';
            }
        }

        // Currency symbol helper
        function getCurrencySymbol(currency) {
            const symbols = { 'EUR': '€', 'CHF': 'CHF', 'USD': '$', 'GBP': '£' };
            return symbols[currency] || currency;
        }
        
        // Create flight card HTML
        function createFlightCard(flight, type, index) {
            const hasValidPrice = flight.price !== null && flight.price !== undefined && !isNaN(parseFloat(flight.price)) && parseFloat(flight.price) > 0;
            const currencySymbol = hasValidPrice ? getCurrencySymbol(flight.currency) : '';
            const noPriceMessage = 'There are no seats available for the selected adults and children.';

            const priceHtml = hasValidPrice
                ? `<div class="price">
                        <span class="currency">${currencySymbol}</span>
                        <span class="amount">${flight.price}</span>
                   </div>`
                : `<div class="price no-price" title="${noPriceMessage}">
                        <span class="amount">—</span>
                   </div>`;

            const selectBtnHtml = hasValidPrice
                ? `<button class="select-btn" onclick="selectFlight('${type}', ${index}, '${flight.price}', '${flight.departureTime}', '${flight.arrivalTime}', '${flight.currency}')">
                        Zgjidh
                   </button>`
                : `<button class="select-btn" disabled title="${noPriceMessage}">
                        Zgjidh
                   </button>`;

            return `
                <div class="flight-card ${hasValidPrice ? '' : 'no-price'}"
                     data-type="${type}"
                     data-index="${index}"
                     data-price="${hasValidPrice ? flight.price : ''}"
                     data-currency="${hasValidPrice ? flight.currency : ''}"
                     data-time="${flight.departureTime}"
                     title="${hasValidPrice ? '' : noPriceMessage}">
                    <div class="flight-main">
                        <div class="flight-time departure">
                            <span class="time">${flight.departureTime}</span>
                            <span class="airport">${flight.fromCode}</span>
                        </div>
                        <div class="flight-duration">
                            <div class="duration-line">
                                <span class="dot"></span>
                                <span class="line"></span>
                                <i class="fas fa-plane"></i>
                                <span class="line"></span>
                                <span class="dot"></span>
                            </div>
                            <span class="duration-text">${flight.duration}</span>
                            <span class="direct-badge">Direct</span>
                        </div>
                        <div class="flight-time arrival">
                            <span class="time">${flight.arrivalTime}</span>
                            <span class="airport">${flight.toCode}</span>
                        </div>
                    </div>
                    <div class="flight-price-section">
                        ${priceHtml}
                        ${selectBtnHtml}
                    </div>
                </div>
            `;
        }

        // Select a flight
        function selectFlight(type, index, price, depTime, arrTime, currency = 'EUR') {
            // Don't allow selecting flights without a real price (we treat as no seats)
            const parsed = parseFloat(price);
            if (isNaN(parsed) || parsed <= 0) {
                return;
            }
            // Remove previous selection of this type
            document.querySelectorAll(`.flight-card[data-type="${type}"]`).forEach(card => {
                card.classList.remove('selected');
            });
            
            // Select this card
            const card = document.querySelector(`.flight-card[data-type="${type}"][data-index="${index}"]`);
            if (card) {
                card.classList.add('selected');
            }
            
            // Update selection state
            const currencySymbol = getCurrencySymbol(currency);
            const flightInfo = `${depTime} → ${arrTime} (${currencySymbol} ${price})`;
            
            if (type === 'outbound') {
                selectedOutbound = { price: parseFloat(price), info: flightInfo, currency: currency };
                document.getElementById('selectedOutbound').textContent = flightInfo;
            } else {
                selectedReturn = { price: parseFloat(price), info: flightInfo, currency: currency };
                document.getElementById('selectedReturn').textContent = flightInfo;
            }
            
            // Update total
            updateTotal();
        }

        // Update total price
        function updateTotal() {
            const outboundPrice = selectedOutbound ? selectedOutbound.price : 0;
            const returnPrice = selectedReturn ? selectedReturn.price : 0;
            const total = outboundPrice + returnPrice;
            // Use the currency from selected flights (default to EUR)
            const currency = selectedOutbound?.currency || selectedReturn?.currency || 'EUR';
            const currencySymbol = getCurrencySymbol(currency);
            document.getElementById('totalPrice').textContent = `${currencySymbol} ${total.toFixed(2)}`;
        }

        // Render flights
        function renderFlights(data) {
            const outboundContainer = document.getElementById('outboundFlights');
            const returnContainer = document.getElementById('returnFlights');
            
            // Get airport codes for display
            const fromCode = cities[searchParams.departure] || 'PRN';
            const toCode = cities[searchParams.destination] || 'BSL';
            
            // Debug: Log what we received
            console.log('📦 API Response:', data);
            console.log('📦 Outbound flights raw:', data.flights?.outbound?.flights);
            console.log('📦 Return flights raw:', data.flights?.return?.flights);
            
            // Render outbound flights
            if (data.flights && data.flights.outbound && data.flights.outbound.flights && data.flights.outbound.flights.length > 0) {
                // IMPORTANT: do NOT filter out flights with missing price.
                // We show them without a price and with a hover message instead.
                const outboundFlights = data.flights.outbound.flights.map(f => ({
                    ...f,
                    fromCode: f.fromCode || fromCode,
                    toCode: f.toCode || toCode
                }));
                outboundContainer.innerHTML = outboundFlights
                    .map((f, i) => createFlightCard(f, 'outbound', i))
                    .join('');
            } else {
                outboundContainer.innerHTML = createNoFlightsMessage(data, 'outbound');
            }
            
            // Render return flights
            if (searchParams.tripType === 'roundtrip') {
                if (data.flights && data.flights.return && data.flights.return.flights && data.flights.return.flights.length > 0) {
                    // IMPORTANT: do NOT filter out flights with missing price.
                    const returnFlights = data.flights.return.flights.map(f => ({
                        ...f,
                        fromCode: f.fromCode || toCode,
                        toCode: f.toCode || fromCode
                    }));
                    returnContainer.innerHTML = returnFlights
                        .map((f, i) => createFlightCard(f, 'return', i))
                        .join('');
            } else {
                returnContainer.innerHTML = createNoFlightsMessage(data, 'return');
            }
        }
        
        // Create detailed no-flights message with debug info
        function createNoFlightsMessage(data, type) {
            const rawFlights = type === 'outbound' 
                ? data.flights?.outbound?.flights 
                : data.flights?.return?.flights;
            
            const debugInfo = data.timing?.searchId 
                ? `<br><small class="debug-id">Search ID: ${data.timing.searchId}</small>` 
                : '';
            
            // Check if there were flights that got filtered out
            // We no longer filter out flights with missing price, so this case isn't needed.
            
            return `
                <div class="no-flights">
                    <i class="fas fa-info-circle"></i>
                    <p>Nuk u gjetën fluturime për datën e zgjedhur</p>
                    <small>Scraper returned ${rawFlights?.length || 0} flights</small>
                    ${debugInfo}
                </div>
            `;
        }
        }

        // Search flights (job-based: returns jobId immediately + polling)
        async function searchFlights() {
            updateHeader();
            
            // ⏱️ Track API call timing
            frontendTiming.apiCallStart = performance.now();
            
            try {
                const response = await fetch('/api/search', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(searchParams)
                });
                
                const { jobId } = await response.json();
                if (!jobId) throw new Error('No jobId returned from server');
                
                // ⏱️ Track API call end
                frontendTiming.apiCallEnd = performance.now();

                // Poll for completion
                const pollStart = performance.now();
                let attempt = 0;
                while (true) {
                    attempt++;
                    const jobResp = await fetch(`/api/jobs/${jobId}`);
                    const job = await jobResp.json();
                    const status = job?.status;

                    // Update loader text based on status
                    const sub = document.querySelector('.loader-subtext');
                    if (sub) {
                        if (status === 'queued') sub.textContent = 'High demand, preparing search…';
                        else if (status === 'running') sub.textContent = 'Searching…';
                        else sub.textContent = 'Processing…';
                    }

                    if (status === 'done') {
                        const data = job.result;

                        // ⏱️ Track render start
                        frontendTiming.renderStart = performance.now();

                        document.getElementById('loadingState').style.display = 'none';
                        document.getElementById('flightsResults').style.display = 'block';

                        renderFlights(data);

                        // ⏱️ Track render end
                        frontendTiming.renderEnd = performance.now();
                        frontendTiming.resultsRenderedEpoch = Date.now();

                        // Display and report timing
                        displayTimingInfo(data?.timing);

                        // Clear stored click timestamp so it doesn't affect later navigations.
                        try { sessionStorage.removeItem('ak_search_click_ts'); } catch (e) {}
                        break;
                    }

                    if (status === 'failed') {
                        throw new Error(job?.error || 'Job failed');
                    }

                    // Poll interval 500–900ms (jitter)
                    const waitMs = 500 + Math.floor(Math.random() * 400);
                    await new Promise(r => setTimeout(r, waitMs));

                    // Hard client-side safety stop (60s)
                    if (performance.now() - pollStart > 60000) {
                        throw new Error('Search is taking too long. Please try again.');
                    }
                }
                
            } catch (error) {
                console.error('Search error:', error);
                frontendTiming.apiCallEnd = performance.now();
                
                document.getElementById('loadingState').style.display = 'none';
                document.getElementById('flightsResults').style.display = 'block';
                
                document.getElementById('outboundFlights').innerHTML = `
                    <div class="no-flights error">
                        <i class="fas fa-exclamation-circle"></i>
                        <p>Ndodhi një gabim gjatë kërkimit. Ju lutemi provoni përsëri.</p>
                        <small style="display:block;margin-top:6px;opacity:0.85;">${error.message || ''}</small>
                        <button class="modify-search-btn" onclick="window.location.reload()" style="margin-top:12px;">
                            <i class="fas fa-rotate-right"></i> Try again
                        </button>
                    </div>
                `;
                if (searchParams.tripType === 'roundtrip') {
                    document.getElementById('returnFlights').innerHTML = `
                        <div class="no-flights error">
                            <i class="fas fa-exclamation-circle"></i>
                            <p>Ndodhi një gabim gjatë kërkimit. Ju lutemi provoni përsëri.</p>
                        </div>
                    `;
                }
            }
        }
        
        // Display timing information
        function displayTimingInfo(backendTiming) {
            const apiTime = frontendTiming.apiCallEnd - frontendTiming.apiCallStart;
            const renderTime = frontendTiming.renderEnd - frontendTiming.renderStart;
            const totalFrontendTime = frontendTiming.renderEnd - frontendTiming.pageLoadStart;
            const totalUserPerceivedMs = apiTime + renderTime;
            const clickToResultsMs =
                frontendTiming.searchClickEpoch && frontendTiming.resultsRenderedEpoch
                    ? (frontendTiming.resultsRenderedEpoch - frontendTiming.searchClickEpoch)
                    : totalUserPerceivedMs;
            
            // Create timing panel
            const timingPanel = document.createElement('div');
            timingPanel.className = 'timing-panel';
            timingPanel.innerHTML = `
                <div class="timing-header">
                    <span><i class="fas fa-stopwatch"></i> Performance Timing</span>
                    <button class="timing-toggle" onclick="toggleTimingDetails()">
                        <i class="fas fa-chevron-down"></i>
                    </button>
                </div>
                <div class="timing-summary">
                    <span class="timing-total">Total (Click → Results): <strong>${formatTime(clickToResultsMs)}</strong></span>
                    <span class="timing-id">ID: ${backendTiming?.searchId || 'N/A'}</span>
                </div>
                <div class="timing-details" id="timingDetails" style="display: none;">
                    <div class="timing-section">
                        <h4><i class="fas fa-server"></i> Backend (Scraper)</h4>
                        <div class="timing-row">
                            <span>Browser Launch</span>
                            <span>${formatTime(backendTiming?.breakdown?.browserLaunch)}</span>
                        </div>
                        <div class="timing-row">
                            <span>Page Navigation</span>
                            <span>${formatTime(backendTiming?.breakdown?.pageNavigation)}</span>
                        </div>
                        <div class="timing-row">
                            <span>Form Filling</span>
                            <span>${formatTime(backendTiming?.breakdown?.formFilling)}</span>
                        </div>
                        <div class="timing-row">
                            <span>Click Search</span>
                            <span>${formatTime(backendTiming?.breakdown?.clickSearch)}</span>
                        </div>
                        <div class="timing-row highlight">
                            <span>Wait for Results</span>
                            <span>${formatTime(backendTiming?.breakdown?.waitForResults)}</span>
                        </div>
                        <div class="timing-row">
                            <span>Data Extraction</span>
                            <span>${formatTime(backendTiming?.breakdown?.dataExtraction)}</span>
                        </div>
                        <div class="timing-row">
                            <span>Browser Close</span>
                            <span>${formatTime(backendTiming?.breakdown?.browserClose)}</span>
                        </div>
                    </div>
                    <div class="timing-section">
                        <h4><i class="fas fa-desktop"></i> Frontend</h4>
                        <div class="timing-row highlight">
                            <span>Click → Results</span>
                            <span>${formatTime(clickToResultsMs)}</span>
                        </div>
                        <div class="timing-row">
                            <span>API Round Trip</span>
                            <span>${formatTime(apiTime)}</span>
                        </div>
                        <div class="timing-row">
                            <span>Render Flights</span>
                            <span>${formatTime(renderTime)}</span>
                        </div>
                        <div class="timing-row highlight">
                            <span>Total (API + Render)</span>
                            <span>${formatTime(totalUserPerceivedMs)}</span>
                        </div>
                    </div>
                </div>
            `;
            
            // Insert after search summary
            const searchSummary = document.querySelector('.search-summary');
            if (searchSummary) {
                searchSummary.after(timingPanel);
            }
            
            // Also send timing to server for logging
            reportFrontendTiming(backendTiming?.searchId, {
                apiRoundTrip: apiTime,
                renderTime: renderTime,
                totalFrontendTime: totalFrontendTime
            });
            
            // Console log for debugging
            console.log('⏱️ Performance Timing:', {
                backend: backendTiming,
                frontend: {
                    apiRoundTrip: `${apiTime.toFixed(0)}ms`,
                    renderTime: `${renderTime.toFixed(0)}ms`,
                    totalFrontend: `${totalFrontendTime.toFixed(0)}ms`
                }
            });
        }
        
        // Always show seconds (ms is hard to read and makes totals look "wrong")
        function formatTime(ms) {
            if (ms === undefined || ms === null) return '—';
            return `${(ms / 1000).toFixed(2)}s`;
        }
        
        function toggleTimingDetails() {
            const details = document.getElementById('timingDetails');
            const icon = document.querySelector('.timing-toggle i');
            if (details.style.display === 'none') {
                details.style.display = 'block';
                icon.classList.replace('fa-chevron-down', 'fa-chevron-up');
            } else {
                details.style.display = 'none';
                icon.classList.replace('fa-chevron-up', 'fa-chevron-down');
            }
        }
        
        // Report frontend timing back to server
        async function reportFrontendTiming(searchId, timing) {
            if (!searchId) return;
            
            try {
                await fetch('/api/timing/frontend', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ searchId, timing })
                });
            } catch (e) {
                console.log('Could not report frontend timing:', e.message);
            }
        }

        // Handle booking button click
        document.getElementById('bookNowBtn').addEventListener('click', () => {
            if (!selectedOutbound) {
                alert('Ju lutemi zgjidhni fluturimin e nisjes');
                return;
            }
            
            if (searchParams.tripType === 'roundtrip' && !selectedReturn) {
                alert('Ju lutemi zgjidhni fluturimin e kthimit');
                return;
            }
            
            const bookingData = {
                departure: searchParams.departure,
                destination: searchParams.destination,
                departureDate: searchParams.departureDate,
                returnDate: searchParams.returnDate,
                tripType: searchParams.tripType,
                adults: searchParams.adults,
                children: searchParams.children,
                infants: searchParams.infants,
                outbound: {
                    time: selectedOutbound.info.split(' (')[0],
                    price: selectedOutbound.price
                }
            };
            
            if (selectedReturn) {
                bookingData.return = {
                    time: selectedReturn.info.split(' (')[0],
                    price: selectedReturn.price
                };
            }
            
            sessionStorage.setItem('bookingData', JSON.stringify(bookingData));
            window.location.href = '/auth';
        });

        // Mobile menu
        function initMobileMenu() {
            const hamburger = document.getElementById('hamburgerBtn');
            const mobileMenu = document.getElementById('mobileMenu');
            const mobileOverlay = document.getElementById('mobileOverlay');
            
            if (!hamburger || !mobileMenu) return;
            
            const toggleMenu = () => {
                hamburger.classList.toggle('active');
                mobileMenu.classList.toggle('open');
                mobileOverlay.classList.toggle('show');
                document.body.classList.toggle('menu-open');
            };
            
            hamburger.addEventListener('click', toggleMenu);
            if (mobileOverlay) {
                mobileOverlay.addEventListener('click', toggleMenu);
            }
            
            mobileMenu.querySelectorAll('a').forEach(link => {
                link.addEventListener('click', () => {
                    hamburger.classList.remove('active');
                    mobileMenu.classList.remove('open');
                    mobileOverlay.classList.remove('show');
                    document.body.classList.remove('menu-open');
                });
            });
        }

        // Initialize
        document.addEventListener('DOMContentLoaded', () => {
            updateHeader();
            searchFlights();
            initMobileMenu();
        });
    </script>
</body>
</html>
