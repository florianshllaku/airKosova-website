    <a href="https://web.whatsapp.com/send?phone=+38344955955" target="_blank" class="whatsapp-widget" title="Chat on WhatsApp">
        <i class="fab fa-whatsapp"></i>
    </a>

    <script src="/js/main.js"></script>
    <script>
        // Translations object for JavaScript
        const translations = {
            login_loading: '<%= t.login_loading %>',
            login_success: '<%= t.login_success %>',
            login_error_generic: '<%= t.login_error_generic %>',
            login_button: '<%= t.login_button %>',
            tab_login: '<%= t.tab_login %>',
            logout: '<%= t.logout %>'
        };
        
        // Get elements
        const loginTab = document.getElementById('loginTab');
        const topLoginBtn = document.getElementById('topLoginBtn');
        const userMenu = document.getElementById('userMenu');
        const userName = document.getElementById('userName');
        const userAvatar = document.getElementById('userAvatar');
        const logoutBtn = document.getElementById('logoutBtn');
        const flightsTab = document.getElementById('flightsTab');
        
        // Language switcher
        document.querySelectorAll('.language-selector span').forEach(btn => {
            btn.addEventListener('click', async () => {
                const lang = btn.dataset.lang;
                try {
                    const response = await fetch(`/api/lang/${lang}`);
                    const data = await response.json();
                    if (data.success) {
                        window.location.reload();
                    }
                } catch (error) {
                    console.error('Language switch error:', error);
                }
            });
        });
        
        // Top bar login button - triggers the login tab
        topLoginBtn.addEventListener('click', (e) => {
            e.preventDefault();
            loginTab.click();
            document.querySelector('.booking-container').scrollIntoView({ behavior: 'smooth' });
        });
        
        // Check if user is logged in
        async function checkAuth() {
            try {
                const response = await fetch('/api/auth/user');
                const data = await response.json();
                
                if (data.success && data.user) {
                    showUserMenu(data.user);
                } else {
                    showLoginButton();
                }
            } catch (error) {
                console.error('Auth check error:', error);
                showLoginButton();
            }
        }
        
        // Show user menu when logged in
        function showUserMenu(user) {
            topLoginBtn.style.display = 'none';
            userMenu.classList.add('show');
            
            const displayName = user.firstName || user.email.split('@')[0];
            userName.textContent = displayName;
            userAvatar.textContent = displayName.charAt(0).toUpperCase();
            
            loginTab.innerHTML = '<i class="fas fa-user"></i> ' + displayName;
        }
        
        // Show login button when not logged in
        function showLoginButton() {
            topLoginBtn.style.display = 'flex';
            userMenu.classList.remove('show');
            loginTab.innerHTML = '<i class="fas fa-user"></i> ' + translations.tab_login;
        }
        
        // Login form submission
        document.getElementById('loginFormElement').addEventListener('submit', async (e) => {
            e.preventDefault();
            
            const email = document.getElementById('loginEmail').value;
            const password = document.getElementById('loginPassword').value;
            const loginBtn = document.getElementById('loginBtn');
            const loginError = document.getElementById('loginError');
            
            // Reset errors
            document.querySelectorAll('.error-message').forEach(el => el.classList.remove('show'));
            document.querySelectorAll('#loginForm input').forEach(el => el.classList.remove('error'));
            
            // Validate email
            if (!email || !/\S+@\S+\.\S+/.test(email)) {
                document.getElementById('loginEmail').classList.add('error');
                document.getElementById('emailError').classList.add('show');
                return;
            }
            
            // Disable button
            loginBtn.disabled = true;
            loginBtn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> ' + translations.login_loading;
            
            try {
                const response = await fetch('/api/auth/login', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ email, password })
                });
                
                const data = await response.json();
                
                if (data.success) {
                    sessionStorage.setItem('user', JSON.stringify(data.user));
                    showUserMenu(data.user);
                    flightsTab.click();
                    
                    loginError.textContent = translations.login_success;
                    loginError.style.color = '#22c55e';
                    loginError.classList.add('show');
                    
                    setTimeout(() => {
                        loginError.classList.remove('show');
                        loginError.style.color = '#ef4444';
                    }, 2000);
                } else {
                    loginError.textContent = data.message || translations.login_error_generic;
                    loginError.classList.add('show');
                }
            } catch (error) {
                loginError.textContent = translations.login_error_generic;
                loginError.classList.add('show');
            } finally {
                loginBtn.disabled = false;
                loginBtn.innerHTML = '<i class="fas fa-arrow-right"></i> ' + translations.login_button;
            }
        });
        
        // Logout functionality
        logoutBtn.addEventListener('click', async () => {
            try {
                await fetch('/api/auth/logout', { method: 'POST' });
                sessionStorage.removeItem('user');
                showLoginButton();
                document.getElementById('loginFormElement').reset();
            } catch (error) {
                console.error('Logout error:', error);
            }
        });
        
        // Check auth on page load
        checkAuth();
        
        // Footer login button
        document.getElementById('footerLoginBtn').addEventListener('click', (e) => {
            e.preventDefault();
            loginTab.click();
            document.querySelector('.booking-container').scrollIntoView({ behavior: 'smooth' });
        });
        
        // Footer language switcher
        document.querySelectorAll('.footer-languages a').forEach(btn => {
            btn.addEventListener('click', async (e) => {
                e.preventDefault();
                const lang = btn.dataset.lang;
                try {
                    const response = await fetch(`/api/lang/${lang}`);
                    const data = await response.json();
                    if (data.success) {
                        window.location.reload();
                    }
                } catch (error) {
                    console.error('Language switch error:', error);
                }
            });
        });
    </script>
</body>
</html>
