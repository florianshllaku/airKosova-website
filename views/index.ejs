<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>AirKosova – Cheap Flights to Kosovo & Europe</title>
  <meta name="description" content="Book affordable flights to Prishtina, Kosovo and major European cities. 10+ years of trusted service." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/styles.css" />
  <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
</head>
<body class="home">
  <!-- Top Bar -->
  <div class="topbar">
    <div class="topbar-inner">
      <div class="topbar-left">
        <a class="topbar-item" href="tel:+38338660880">+383 38 660 880</a>
        <a class="topbar-item" href="tel:+38344955955">+383 44 955 955</a>
        <a class="topbar-item" href="mailto:info@airkosova.net">info@airkosova.net</a>
      </div>
      <div class="topbar-right">
        <span class="topbar-lang" data-lang="sq">AL</span>
        <span class="topbar-lang" data-lang="de">DE</span>
        <span class="topbar-lang active" data-lang="en">EN</span>
      </div>
    </div>
  </div>

  <div class="hero-page">
    <!-- Navigation -->
    <nav class="hero-nav">
      <div class="nav-row">
        <div class="brand">
          <a href="/">
            <img class="brand-logo" src="/images/airkosova_logo.png" alt="AirKosova" />
          </a>
        </div>
        <div class="nav-links">
          <a class="nav-link active" href="#" data-i18n="nav_book">Book</a>
          <a class="nav-link" href="#" data-i18n="nav_info">Information</a>
          <a class="nav-link" href="#" data-i18n="nav_contact">Contact</a>
          <a class="nav-link" href="#" data-i18n="nav_booking">My Booking</a>
        </div>
      </div>
    </nav>

    <!-- Booking Section -->
    <div class="booking-wrap">
      <div class="booking-card">
        <div class="booking-header">
          <div class="booking-title" data-i18n="booking_title">Book Your Flight</div>
          <div class="booking-tabs">
            <button class="booking-tab active" id="tabFlights" data-i18n="tab_flights">Flights</button>
            <button class="booking-tab" id="tabLogin" data-i18n="tab_login">Login</button>
          </div>
        </div>

        <!-- Flights Form -->
        <form id="searchForm" class="booking-form">
          <div class="grid">
            <label class="field">
              <span class="field-label" data-i18n="field_from">From</span>
              <select name="departure" required>
                <option value="PRN" selected>Prishtina (PRN)</option>
                <option value="ARN">Stockholm (ARN)</option>
                <option value="BER">Berlin Brandenburg (BER)</option>
                <option value="BGY">Milano Bergamo (BGY)</option>
                <option value="BRE">Bremen (BRE)</option>
                <option value="BRU">Brussels (BRU)</option>
                <option value="BSL">Basel (BSL)</option>
                <option value="CGN">Köln/Bonn (CGN)</option>
                <option value="DTM">Dortmund (DTM)</option>
                <option value="DUS">Düsseldorf (DUS)</option>
                <option value="FMM">Memmingen (FMM)</option>
                <option value="FMO">Münster-Osnabrück (FMO)</option>
                <option value="GOT">Göteborg Landvetter (GOT)</option>
                <option value="GVA">Geneva (GVA)</option>
                <option value="HAJ">Hannover (HAJ)</option>
                <option value="HAM">Hamburg (HAM)</option>
                <option value="HEL">Helsinki (HEL)</option>
                <option value="LJU">Ljubljana (LJU)</option>
                <option value="LUX">Luxembourg (LUX)</option>
                <option value="MMX">Malmö (MMX)</option>
                <option value="MUC">München (MUC)</option>
                <option value="NUE">Nürnberg (NUE)</option>
                <option value="OSL">Oslo (OSL)</option>
                <option value="STR">Stuttgart (STR)</option>
                <option value="SZG">Salzburg (SZG)</option>
                <option value="VIE">Vienna (VIE)</option>
                <option value="VXO">Växjö-Småland (VXO)</option>
                <option value="ZRH">Zürich (ZRH)</option>
              </select>
            </label>

            <label class="field">
              <span class="field-label" data-i18n="field_to">To</span>
              <select name="destination" required>
                <option value="PRN">Prishtina (PRN)</option>
                <option value="ARN">Stockholm (ARN)</option>
                <option value="BER">Berlin Brandenburg (BER)</option>
                <option value="BGY">Milano Bergamo (BGY)</option>
                <option value="BRE">Bremen (BRE)</option>
                <option value="BRU">Brussels (BRU)</option>
                <option value="BSL" selected>Basel (BSL)</option>
                <option value="CGN">Köln/Bonn (CGN)</option>
                <option value="DTM">Dortmund (DTM)</option>
                <option value="DUS">Düsseldorf (DUS)</option>
                <option value="FMM">Memmingen (FMM)</option>
                <option value="FMO">Münster-Osnabrück (FMO)</option>
                <option value="GOT">Göteborg Landvetter (GOT)</option>
                <option value="GVA">Geneva (GVA)</option>
                <option value="HAJ">Hannover (HAJ)</option>
                <option value="HAM">Hamburg (HAM)</option>
                <option value="HEL">Helsinki (HEL)</option>
                <option value="LJU">Ljubljana (LJU)</option>
                <option value="LUX">Luxembourg (LUX)</option>
                <option value="MMX">Malmö (MMX)</option>
                <option value="MUC">München (MUC)</option>
                <option value="NUE">Nürnberg (NUE)</option>
                <option value="OSL">Oslo (OSL)</option>
                <option value="STR">Stuttgart (STR)</option>
                <option value="SZG">Salzburg (SZG)</option>
                <option value="VIE">Vienna (VIE)</option>
                <option value="VXO">Växjö-Småland (VXO)</option>
                <option value="ZRH">Zürich (ZRH)</option>
              </select>
            </label>

            <label class="field">
              <span class="field-label" data-i18n="field_departure">Departure</span>
              <input name="departureDate" type="date" required />
            </label>

            <label class="field">
              <span class="field-label" data-i18n="field_return">Return</span>
              <input name="returnDate" type="date" />
            </label>
          </div>

          <div class="grid" style="grid-template-columns: repeat(3, 1fr); margin-top: 16px;">
            <label class="field">
              <span class="field-label" data-i18n="field_adults">Adults</span>
              <input name="adults" type="number" min="1" max="9" value="1" />
            </label>

            <label class="field">
              <span class="field-label" data-i18n="field_children">Children (2-11)</span>
              <input name="children" type="number" min="0" max="9" value="0" />
            </label>

            <label class="field">
              <span class="field-label" data-i18n="field_infants">Infants (0-2)</span>
              <input name="infants" type="number" min="0" max="9" value="0" />
            </label>
          </div>

          <div id="passengerError" class="passenger-error" style="display: none;" data-i18n="error_passengers">Maximum 5 passengers allowed per booking.</div>

          <div class="booking-row">
            <div class="booking-radios">
              <label class="radio">
                <input type="radio" name="tripType" value="roundtrip" checked />
                <span data-i18n="trip_roundtrip">Round Trip</span>
              </label>
              <label class="radio">
                <input type="radio" name="tripType" value="oneway" />
                <span data-i18n="trip_oneway">One Way</span>
              </label>
              <span class="eur-note" data-i18n="prices_eur">All prices in EUR</span>
            </div>

            <div class="booking-actions">
              <input type="hidden" name="openBrowser" value="<%= openBrowserOnSearch ? 'on' : '' %>" />
              <input type="hidden" name="keepBrowserOpenMs" value="<%= keepBrowserOpenMs %>" />
              <button class="btn booking-btn" type="submit" id="searchBtn" data-i18n="btn_search">Search Flights</button>
            </div>
          </div>
        </form>

        <!-- Login Form (hidden by default) -->
        <div id="loginFormContainer" class="login-form-container" style="display: none;">
          <div class="login-form-inner">
            <h3 data-i18n="login_title">Customer Login</h3>
            <p class="login-subtitle" data-i18n="login_subtitle">Sign in to manage your bookings</p>
            
            <form id="loginForm" class="auth-form">
              <div class="auth-field">
                <label for="loginEmail" data-i18n="login_email">Email</label>
                <input type="email" id="loginEmail" name="email" placeholder="your@email.com" required />
              </div>
              <div class="auth-field">
                <label for="loginPassword" data-i18n="login_password">Password</label>
                <input type="password" id="loginPassword" name="password" placeholder="••••••••" required />
              </div>
              <div id="loginError" class="auth-error" style="display: none;"></div>
              <button type="submit" class="btn booking-btn auth-btn" id="loginSubmitBtn" data-i18n="login_btn">Sign In</button>
            </form>
            
            <div class="auth-divider">
              <span data-i18n="login_or">or</span>
            </div>
            
            <div class="auth-links">
              <p><span data-i18n="login_no_account">Don't have an account?</span> <a href="#" id="showRegister" data-i18n="login_register">Register</a></p>
              <p><a href="#" id="showForgotPassword" data-i18n="login_forgot">Forgot password?</a></p>
            </div>
          </div>
          
          <!-- Register Form (hidden) -->
          <div id="registerFormContainer" class="login-form-inner" style="display: none;">
            <h3 data-i18n="register_title">Create Account</h3>
            <p class="login-subtitle" data-i18n="register_subtitle">Sign up to book and manage flights</p>
            
            <form id="registerForm" class="auth-form">
              <div class="auth-field">
                <label for="registerEmail" data-i18n="register_email">Email</label>
                <input type="email" id="registerEmail" name="email" placeholder="your@email.com" required />
              </div>
              <div class="auth-field">
                <label for="registerPassword" data-i18n="register_password">Password</label>
                <input type="password" id="registerPassword" name="password" placeholder="••••••••" minlength="6" required />
              </div>
              <div class="auth-field">
                <label for="registerPasswordConfirm" data-i18n="register_confirm">Confirm Password</label>
                <input type="password" id="registerPasswordConfirm" name="passwordConfirm" placeholder="••••••••" minlength="6" required />
              </div>
              <div id="registerError" class="auth-error" style="display: none;"></div>
              <div id="registerSuccess" class="auth-success" style="display: none;"></div>
              <button type="submit" class="btn booking-btn auth-btn" id="registerSubmitBtn" data-i18n="register_btn">Create Account</button>
            </form>
            
            <div class="auth-links" style="margin-top: 20px;">
              <p><span data-i18n="register_have_account">Already have an account?</span> <a href="#" id="showLogin" data-i18n="register_login">Sign In</a></p>
            </div>
          </div>
          
          <!-- Forgot Password Form (hidden) -->
          <div id="forgotFormContainer" class="login-form-inner" style="display: none;">
            <h3 data-i18n="forgot_title">Reset Password</h3>
            <p class="login-subtitle" data-i18n="forgot_subtitle">Enter your email to receive a reset link</p>
            
            <form id="forgotForm" class="auth-form">
              <div class="auth-field">
                <label for="forgotEmail" data-i18n="forgot_email">Email</label>
                <input type="email" id="forgotEmail" name="email" placeholder="your@email.com" required />
              </div>
              <div id="forgotError" class="auth-error" style="display: none;"></div>
              <div id="forgotSuccess" class="auth-success" style="display: none;"></div>
              <button type="submit" class="btn booking-btn auth-btn" id="forgotSubmitBtn" data-i18n="forgot_btn">Send Reset Link</button>
            </form>
            
            <div class="auth-links" style="margin-top: 20px;">
              <p><a href="#" id="backToLogin" data-i18n="forgot_back">← Back to Sign In</a></p>
            </div>
          </div>
          
          <!-- Logged In State (hidden) -->
          <div id="loggedInContainer" class="login-form-inner" style="display: none;">
            <div class="user-welcome">
              <div class="user-avatar" id="userAvatar">U</div>
              <h3 data-i18n="welcome_title">Welcome back!</h3>
              <p id="userEmail" class="user-email"></p>
            </div>
            <button type="button" class="btn secondary auth-btn" id="logoutBtn" data-i18n="logout_btn">Sign Out</button>
          </div>
        </div>
      </div>
    </div>

    <!-- Below Fold -->
    <div class="below-fold">
      <!-- Call Center & My Booking -->
      <section class="strip">
        <div class="strip-card">
          <h3 data-i18n="callcenter_title">Call Center</h3>
          <p><strong data-i18n="callcenter_hours">Hours:</strong> 09:00 - 22:00 (Mon - Sun)</p>
          <p><strong>Kosovo:</strong> +383 38 660 880 / +383 44 955 955</p>
          <p><strong>Switzerland:</strong> +41 43 505 28 80</p>
        </div>
        <div class="strip-card">
          <h3 data-i18n="mybooking_title">My Booking</h3>
          <p class="muted" data-i18n="mybooking_desc">Retrieve your booking details</p>
          <form class="mini-login" onsubmit="return false;">
            <label>
              <span data-i18n="mybooking_ref">Booking Reference</span>
              <input type="text" placeholder="e.g. AK12345" />
            </label>
            <label>
              <span data-i18n="mybooking_name">Last Name</span>
              <input type="text" placeholder="Surname" />
            </label>
            <button class="btn secondary" type="submit" data-i18n="mybooking_btn">Find</button>
          </form>
        </div>
      </section>

      <!-- Features -->
      <section class="features">
        <div class="feature">
          <h3 data-i18n="feature1_title">10+ Years Experience</h3>
          <p data-i18n="feature1_desc">Trusted by thousands of travelers since 2014. Safe, reliable, and professional service you can count on.</p>
        </div>
        <div class="feature">
          <h3 data-i18n="feature2_title">Easy Online Booking</h3>
          <p data-i18n="feature2_desc">Book your flights in minutes with our simple booking system. Secure payments via Visa and Mastercard.</p>
        </div>
        <div class="feature">
          <h3 data-i18n="feature3_title">24/7 Customer Support</h3>
          <p data-i18n="feature3_desc">Our dedicated team is always ready to assist you with any questions or booking changes.</p>
        </div>
      </section>

      <!-- Destinations -->
      <section class="destinations">
        <div class="section-head">
          <h2 data-i18n="destinations_title">Popular Destinations</h2>
          <p data-i18n="destinations_desc">Direct flights to the most popular European cities</p>
        </div>
        <div class="dest-grid">
          <a class="dest" href="#">
            <img src="/images/top-destinations/basel.png" alt="Basel" />
            <div class="dest-meta">
              <div class="dest-route">Basel → Prishtina</div>
            </div>
          </a>
          <a class="dest" href="#">
            <img src="/images/top-destinations/prishtina.png" alt="Prishtina" />
            <div class="dest-meta">
              <div class="dest-route">Prishtina → Basel</div>
            </div>
          </a>
          <a class="dest" href="#">
            <img src="/images/top-destinations/dusseldorf.png" alt="Düsseldorf" />
            <div class="dest-meta">
              <div class="dest-route">Düsseldorf → Prishtina</div>
            </div>
          </a>
          <a class="dest" href="#">
            <img src="/images/top-destinations/stuttgart.png" alt="Stuttgart" />
            <div class="dest-meta">
              <div class="dest-route">Stuttgart → Prishtina</div>
            </div>
          </a>
          <a class="dest" href="#">
            <img src="/images/top-destinations/munchen.png" alt="München" />
            <div class="dest-meta">
              <div class="dest-route">München → Prishtina</div>
            </div>
          </a>
          <a class="dest" href="#">
            <img src="/images/top-destinations/nuremberg.png" alt="Nürnberg" />
            <div class="dest-meta">
              <div class="dest-route">Nürnberg → Prishtina</div>
            </div>
          </a>
          <a class="dest" href="#">
            <img src="/images/top-destinations/vaxjo.png" alt="Växjö" />
            <div class="dest-meta">
              <div class="dest-route">Växjö → Prishtina</div>
            </div>
          </a>
          <a class="dest" href="#">
            <img src="/images/top-destinations/munster.png" alt="Münster" />
            <div class="dest-meta">
              <div class="dest-route">Münster → Prishtina</div>
            </div>
          </a>
          <a class="dest" href="#">
            <img src="/images/top-destinations/bremen.png" alt="Bremen" />
            <div class="dest-meta">
              <div class="dest-route">Bremen → Prishtina</div>
            </div>
          </a>
        </div>
      </section>

      <!-- Footer -->
      <footer class="site-footer">
        <div class="footer-grid">
          <div>
            <h4 data-i18n="footer_prishtina">Prishtina Office</h4>
            <p>Bulevardi Bill Klinton 12<br/>10000 Prishtinë, Kosovo</p>
            <p><a href="tel:+38344955955">+383 44 955 955</a></p>
            <p><a href="mailto:info@airkosova.net">info@airkosova.net</a></p>
          </div>
          <div>
            <h4 data-i18n="footer_london">London Office</h4>
            <p>71-75 Shelton Street<br/>Covent Garden, London WC2H 9JQ</p>
            <p><a href="mailto:info@airkosova.net">info@airkosova.net</a></p>
          </div>
          <div>
            <h4 data-i18n="footer_payment">Payment Methods</h4>
            <p>Visa • Mastercard • Bank Transfer</p>
            <h4 style="margin-top: 20px;" data-i18n="footer_languages">Languages</h4>
            <p>Shqip • Deutsch • English</p>
          </div>
        </div>
        <div class="footer-bottom">
          <span>© <%= new Date().getFullYear() %> Airkosova Network SH.P.K. All Rights Reserved.</span>
        </div>
      </footer>
    </div>
  </div>

  <!-- WhatsApp Widget -->
  <a href="https://web.whatsapp.com/send?phone=+38344955955" target="_blank" rel="noopener noreferrer" class="whatsapp-widget" title="Chat with us on WhatsApp">
