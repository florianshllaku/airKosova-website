<!DOCTYPE html>
<html lang="sq">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Hyrja - AirKosova</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <link rel="stylesheet" href="/css/styles.css">
    <style>
        .auth-page {
            min-height: 100vh;
            background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
            display: flex;
            flex-direction: column;
        }
        
        .auth-header {
            background: rgba(0, 0, 0, 0.3);
            padding: 1rem 2rem;
        }
        
        .auth-header .logo-img {
            height: 50px;
        }
        
        .auth-main {
            flex: 1;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 2rem;
        }
        
        .auth-container {
            display: flex;
            gap: 3rem;
            max-width: 1000px;
            width: 100%;
        }
        
        .booking-summary {
            flex: 1;
            background: rgba(255, 255, 255, 0.1);
            backdrop-filter: blur(10px);
            border-radius: 20px;
            padding: 2rem;
            color: white;
        }
        
        .booking-summary h2 {
            font-size: 1.5rem;
            margin-bottom: 1.5rem;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }
        
        .flight-summary {
            background: rgba(0, 0, 0, 0.2);
            border-radius: 12px;
            padding: 1.5rem;
            margin-bottom: 1rem;
        }
        
        .flight-summary .route {
            display: flex;
            align-items: center;
            gap: 1rem;
            margin-bottom: 1rem;
        }
        
        .flight-summary .route .city {
            text-align: center;
        }
        
        .flight-summary .route .city .code {
            font-size: 1.5rem;
            font-weight: 700;
            color: #ffd700;
        }
        
        .flight-summary .route .city .name {
            font-size: 0.85rem;
            opacity: 0.8;
        }
        
        .flight-summary .route .arrow {
            flex: 1;
            text-align: center;
            color: #ffd700;
        }
        
        .flight-summary .time-info {
            display: flex;
            justify-content: space-between;
            font-size: 0.9rem;
            opacity: 0.9;
        }
        
        .price-summary {
            background: linear-gradient(135deg, #ffd700, #ff9500);
            color: #1a1a2e;
            border-radius: 12px;
            padding: 1.5rem;
            text-align: center;
        }
        
        .price-summary .label {
            font-size: 0.9rem;
            margin-bottom: 0.5rem;
        }
        
        .price-summary .amount {
            font-size: 2rem;
            font-weight: 700;
        }
        
        .auth-card {
            flex: 1;
            background: white;
            border-radius: 20px;
            padding: 2.5rem;
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
        }
        
        .auth-card h2 {
            font-size: 1.5rem;
            color: #1a1a2e;
            margin-bottom: 0.5rem;
        }
        
        .auth-card .subtitle {
            color: #666;
            margin-bottom: 2rem;
        }
        
        .form-group {
            margin-bottom: 1.5rem;
        }
        
        .form-group label {
            display: block;
            font-size: 0.9rem;
            font-weight: 500;
            color: #333;
            margin-bottom: 0.5rem;
        }
        
        .form-group input {
            width: 100%;
            padding: 0.9rem 1rem;
            border: 2px solid #e0e0e0;
            border-radius: 10px;
            font-size: 1rem;
            font-family: inherit;
            transition: all 0.3s ease;
        }
        
        .form-group input:focus {
            outline: none;
            border-color: #0f3460;
            box-shadow: 0 0 0 3px rgba(15, 52, 96, 0.1);
        }
        
        .form-group input.error {
            border-color: #e74c3c;
        }
        
        .error-message {
            color: #e74c3c;
            font-size: 0.85rem;
            margin-top: 0.5rem;
            display: none;
        }
        
        .error-message.show {
            display: block;
        }
        
        .btn-primary {
            width: 100%;
            padding: 1rem;
            background: linear-gradient(135deg, #0f3460, #16213e);
            color: white;
            border: none;
            border-radius: 10px;
            font-size: 1rem;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s ease;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 0.5rem;
        }
        
        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 20px rgba(15, 52, 96, 0.3);
        }
        
        .btn-primary:disabled {
            opacity: 0.6;
            cursor: not-allowed;
            transform: none;
        }
        
        .forgot-password {
            text-align: right;
            margin-top: -0.5rem;
            margin-bottom: 1.5rem;
        }
        
        .forgot-password a {
            color: #0f3460;
            font-size: 0.9rem;
            text-decoration: none;
        }
        
        .forgot-password a:hover {
            text-decoration: underline;
        }
        
        .divider {
            display: flex;
            align-items: center;
            margin: 2rem 0;
            color: #999;
        }
        
        .divider::before,
        .divider::after {
            content: '';
            flex: 1;
            height: 1px;
            background: #e0e0e0;
        }
        
        .divider span {
            padding: 0 1rem;
            font-size: 0.9rem;
        }
        
        .new-customer {
            text-align: center;
        }
        
        .new-customer p {
            color: #666;
            margin-bottom: 1rem;
        }
        
        .btn-secondary {
            width: 100%;
            padding: 1rem;
            background: white;
            color: #0f3460;
            border: 2px solid #0f3460;
            border-radius: 10px;
            font-size: 1rem;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s ease;
        }
        
        .btn-secondary:hover {
            background: #f5f5f5;
        }
        
        .auth-footer {
            text-align: center;
            padding: 1rem;
            color: rgba(255, 255, 255, 0.6);
            font-size: 0.9rem;
        }
        
        @media (max-width: 768px) {
            .auth-container {
                flex-direction: column;
            }
            
            .booking-summary {
                order: 2;
            }
            
            .auth-card {
                order: 1;
            }
        }
    </style>
</head>
<body class="auth-page">
    <!-- Header -->
    <header class="auth-header">
        <a href="/" class="logo">
            <img src="/images/airkosova_logo.png" alt="AirKosova" class="logo-img">
        </a>
    </header>

    <!-- Main Content -->
    <main class="auth-main">
        <div class="auth-container">
            <!-- Booking Summary -->
            <div class="booking-summary">
                <h2><i class="fas fa-plane"></i> Rezervimi Juaj</h2>
                
                <!-- Outbound Flight -->
                <div class="flight-summary" id="outboundSummary">
                    <div class="route">
                        <div class="city">
                            <div class="code" id="outFromCode">PRN</div>
                            <div class="name" id="outFromName">Prishtina</div>
                        </div>
                        <div class="arrow">
                            <i class="fas fa-plane"></i>
                            <div style="font-size: 0.8rem; margin-top: 0.3rem;">Nisja</div>
                        </div>
                        <div class="city">
                            <div class="code" id="outToCode">BSL</div>
                            <div class="name" id="outToName">Basel</div>
                        </div>
                    </div>
                    <div class="time-info">
                        <span id="outDate">-</span>
                        <span id="outTime">-</span>
                        <span id="outPrice">CHF -</span>
                    </div>
                </div>
                
                <!-- Return Flight (if round trip) -->
                <div class="flight-summary" id="returnSummary" style="display: none;">
                    <div class="route">
                        <div class="city">
                            <div class="code" id="retFromCode">BSL</div>
                            <div class="name" id="retFromName">Basel</div>
                        </div>
                        <div class="arrow">
                            <i class="fas fa-plane"></i>
                            <div style="font-size: 0.8rem; margin-top: 0.3rem;">Kthimi</div>
                        </div>
                        <div class="city">
                            <div class="code" id="retToCode">PRN</div>
                            <div class="name" id="retToName">Prishtina</div>
                        </div>
                    </div>
                    <div class="time-info">
                        <span id="retDate">-</span>
                        <span id="retTime">-</span>
                        <span id="retPrice">CHF -</span>
                    </div>
                </div>
                
                <!-- Total Price -->
                <div class="price-summary">
                    <div class="label">Totali</div>
                    <div class="amount" id="totalPrice">CHF 0.00</div>
                </div>
            </div>
            
            <!-- Auth Card -->
            <div class="auth-card">
                <h2>A keni llogari me ne?</h2>
                <p class="subtitle">Hyni për të vazhduar me rezervimin</p>
                
                <!-- Login Form -->
                <form id="loginForm">
                    <div class="form-group">
                        <label for="email"><i class="fas fa-envelope"></i> Email</label>
                        <input type="email" id="email" name="email" placeholder="email@shembull.com" required>
                        <div class="error-message" id="emailError">Email-i nuk është i vlefshëm</div>
                    </div>
                    
                    <div class="form-group">
                        <label for="password"><i class="fas fa-lock"></i> Fjalëkalimi</label>
                        <input type="password" id="password" name="password" placeholder="••••••••" required>
                        <div class="error-message" id="passwordError">Fjalëkalimi nuk është i saktë</div>
                    </div>
                    
                    <div class="forgot-password">
                        <a href="/forgot-password">Keni harruar fjalëkalimin?</a>
                    </div>
                    
                    <button type="submit" class="btn-primary" id="loginBtn">
                        <i class="fas fa-sign-in-alt"></i>
                        Hyr
                    </button>
                    
                    <div class="error-message" id="loginError" style="text-align: center; margin-top: 1rem;"></div>
                </form>
                
                <div class="divider">
                    <span>OSE</span>
                </div>
                
                <!-- New Customer Section -->
                <div class="new-customer">
                    <p>Jeni klient i ri ose nuk keni llogari me ne?</p>
                    <button type="button" class="btn-secondary" id="continueBtn">
                        <i class="fas fa-arrow-right"></i>
                        Vazhdo
                    </button>
                </div>
            </div>
        </div>
    </main>

    <!-- Footer -->
    <footer class="auth-footer">
        <p>© 2025 AirKosova - Të gjitha të drejtat e rezervuara</p>
    </footer>

    <script>
        // Get booking data from session storage
        const bookingData = JSON.parse(sessionStorage.getItem('bookingData') || '{}');
        
        // City codes
        const cities = <%- JSON.stringify(cities) %>;
        
        // Populate booking summary
        function populateSummary() {
            if (!bookingData.outbound) return;
            
            const fromCode = cities[bookingData.departure] || 'PRN';
            const toCode = cities[bookingData.destination] || 'BSL';
            
            // Outbound
            document.getElementById('outFromCode').textContent = fromCode;
            document.getElementById('outFromName').textContent = bookingData.departure;
            document.getElementById('outToCode').textContent = toCode;
            document.getElementById('outToName').textContent = bookingData.destination;
            document.getElementById('outDate').textContent = bookingData.departureDate || '-';
            document.getElementById('outTime').textContent = bookingData.outbound.time || '-';
            document.getElementById('outPrice').textContent = `CHF ${bookingData.outbound.price || '0'}`;
            
            // Return (if exists)
            if (bookingData.return && bookingData.tripType === 'roundtrip') {
                document.getElementById('returnSummary').style.display = 'block';
                document.getElementById('retFromCode').textContent = toCode;
                document.getElementById('retFromName').textContent = bookingData.destination;
                document.getElementById('retToCode').textContent = fromCode;
                document.getElementById('retToName').textContent = bookingData.departure;
                document.getElementById('retDate').textContent = bookingData.returnDate || '-';
                document.getElementById('retTime').textContent = bookingData.return.time || '-';
                document.getElementById('retPrice').textContent = `CHF ${bookingData.return.price || '0'}`;
            }
            
            // Total
            const outPrice = parseFloat(bookingData.outbound.price) || 0;
            const retPrice = parseFloat(bookingData.return?.price) || 0;
            document.getElementById('totalPrice').textContent = `CHF ${(outPrice + retPrice).toFixed(2)}`;
        }
        
        // Login form submission
        document.getElementById('loginForm').addEventListener('submit', async (e) => {
            e.preventDefault();
            
            const email = document.getElementById('email').value;
            const password = document.getElementById('password').value;
            const loginBtn = document.getElementById('loginBtn');
            const loginError = document.getElementById('loginError');
            
            // Reset errors
            document.querySelectorAll('.error-message').forEach(el => el.classList.remove('show'));
            document.querySelectorAll('input').forEach(el => el.classList.remove('error'));
            
            // Validate email
            if (!email || !/\S+@\S+\.\S+/.test(email)) {
                document.getElementById('email').classList.add('error');
                document.getElementById('emailError').classList.add('show');
                return;
            }
            
            // Disable button
            loginBtn.disabled = true;
            loginBtn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Duke hyrë...';
            
            try {
                const response = await fetch('/api/auth/login', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ email, password })
                });
                
                const data = await response.json();
                
                if (data.success) {
                    // Store user session
                    sessionStorage.setItem('user', JSON.stringify(data.user));
                    // Redirect to passenger details
                    window.location.href = '/booking/passengers';
                } else {
                    loginError.textContent = data.message || 'Email ose fjalëkalimi nuk është i saktë';
                    loginError.classList.add('show');
                }
            } catch (error) {
                loginError.textContent = 'Ndodhi një gabim. Ju lutemi provoni përsëri.';
                loginError.classList.add('show');
            } finally {
                loginBtn.disabled = false;
                loginBtn.innerHTML = '<i class="fas fa-sign-in-alt"></i> Hyr';
            }
        });
        
        // Continue without account / Register
        document.getElementById('continueBtn').addEventListener('click', () => {
            window.location.href = '/register';
        });
        
        // Initialize
        populateSummary();
    </script>
</body>
</html>





